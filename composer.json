{
    "name": "gregorj/serial-port",
    "description": "PHP interfaces and classes for serial port communication.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Gregor J.",
            "email": "gregor-j@users.noreply.github.com",
            "role": "developer"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-sockets": "*"
    },
    "autoload": {
        "psr-4": {
            "GregorJ\\SerialPort\\": "src"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^4.0",
        "phpstan/phpstan": "^2.1",
        "ext-posix": "*",
        "ext-pcntl": "*"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\GregorJ\\SerialPort\\": "tests/"
        }
    }
}
